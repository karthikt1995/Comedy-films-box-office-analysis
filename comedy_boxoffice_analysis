      "\n",
      "Year range: 2000 - 2016\n"
     ]
    }
   ],
   "source": [
    "# Extract genres (they're stored as JSON-like text, we need to convert them)\n",
    "def extract_genres(genre_str):\n",
    "    try:\n",
    "        genres = ast.literal_eval(genre_str)\n",
    "        return [g['name'] for g in genres]\n",
    "    except:\n",
    "        return []\n",
    "\n",
    "df['genre_list'] = df['genres'].apply(extract_genres)\n",
    "\n",
    "# Filter for Comedy films only\n",
    "comedy_df = df[df['genre_list'].apply(lambda x: 'Comedy' in x)].copy()\n",
    "\n",
    "# Filter for year 2000 onwards\n",
    "comedy_df['release_date'] = pd.to_datetime(comedy_df['release_date'], errors='coerce')\n",
    "comedy_df['year'] = comedy_df['release_date'].dt.year\n",
    "comedy_df = comedy_df[comedy_df['year'] >= 2000].copy()\n",
    "\n",
    "# Remove movies with no budget or revenue data\n",
    "comedy_df = comedy_df[(comedy_df['budget'] > 0) & (comedy_df['revenue'] > 0)].copy()\n",
    "\n",
    "# Add ROI column\n",
    "comedy_df['roi'] = ((comedy_df['revenue'] - comedy_df['budget']) / comedy_df['budget']) * 100\n",
    "\n",
    "print(f\"Total comedy films from 2000 onwards with complete data: {len(comedy_df)}\")\n",
    "print(f\"\\nYear range: {comedy_df['year'].min()} - {comedy_df['year'].max()}\")"
   ]
  },
