   "source": [
    "# CHART 1: Top 20 Highest Grossing Comedy Films (2000-2016)\n",
    "top20 = comedy_df.nlargest(20, 'revenue')[['title', 'revenue']].copy()\n",
    "top20['revenue_millions'] = top20['revenue'] / 1_000_000\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "bars = plt.barh(top20['title'], top20['revenue_millions'], color='steelblue')\n",
    "plt.xlabel('Box Office Revenue ($ Millions)', fontsize=12)\n",
    "plt.title('Top 20 Highest Grossing Comedy Films (2000-2016)', fontsize=14, fontweight='bold')\n",
    "plt.gca().invert_yaxis()\n",
    "\n",
    "# Add value labels on bars\n",
    "for bar, val in zip(bars, top20['revenue_millions']):\n",
    "    plt.text(bar.get_width() + 5, bar.get_y() + bar.get_height()/2,\n",
    "             f'${val:.0f}M', va='center', fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('top20_comedy_revenue.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Chart 1 saved!\")"
