    "# CHART 3: Average Comedy Box Office Revenue by Year (2000-2016)\n",
    "yearly = comedy_df.groupby('year')['revenue'].agg(['mean', 'median']).reset_index()\n",
    "yearly['mean'] = yearly['mean'] / 1_000_000\n",
    "yearly['median'] = yearly['median'] / 1_000_000\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "plt.plot(yearly['year'], yearly['mean'], marker='o', color='steelblue', \n",
    "         linewidth=2, markersize=6, label='Mean Revenue')\n",
    "plt.plot(yearly['year'], yearly['median'], marker='s', color='coral', \n",
    "         linewidth=2, markersize=6, label='Median Revenue')\n",
    "plt.xlabel('Year', fontsize=12)\n",
    "plt.ylabel('Revenue ($ Millions)', fontsize=12)\n",
    "plt.title('Comedy Film Revenue Trends by Year (2000-2016)', \n",
    "          fontsize=13, fontweight='bold')\n",
    "plt.legend()\n",
    "plt.xticks(yearly['year'], rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.savefig('revenue_by_year.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Chart 3 saved!\")"
