    "# CHART 4: Average Revenue by Release Month - Best time to release a comedy?\n",
    "comedy_df['month'] = comedy_df['release_date'].dt.month\n",
    "monthly = comedy_df.groupby('month')['revenue'].mean() / 1_000_000\n",
    "\n",
    "month_names = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', \n",
    "               'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']\n",
    "\n",
    "colors = ['coral' if x == monthly.max() else 'steelblue' for x in monthly]\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "bars = plt.bar(month_names, monthly, color=colors, edgecolor='white')\n",
    "plt.xlabel('Release Month', fontsize=12)\n",
    "plt.ylabel('Average Revenue ($ Millions)', fontsize=12)\n",
    "plt.title('Average Comedy Film Revenue by Release Month (2000-2016)', \n",
    "          fontsize=13, fontweight='bold')\n",
    "\n",
    "# Add value labels on top of bars\n",
    "for bar, val in zip(bars, monthly):\n",
    "    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 2,\n",
    "             f'${val:.0f}M', ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('revenue_by_month.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Chart 4 saved!\")"
