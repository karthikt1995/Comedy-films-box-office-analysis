    "# CHART 2: Budget vs Revenue - Do bigger budgets mean bigger returns?\n",
    "plt.figure(figsize=(10, 7))\n",
    "plt.scatter(comedy_df['budget']/1_000_000, \n",
    "            comedy_df['revenue']/1_000_000, \n",
    "            alpha=0.6, color='steelblue', edgecolors='white', linewidth=0.5)\n",
    "\n",
    "# Add trend line\n",
    "import numpy as np\n",
    "z = np.polyfit(comedy_df['budget']/1_000_000, comedy_df['revenue']/1_000_000, 1)\n",
    "p = np.poly1d(z)\n",
    "x_line = np.linspace(0, comedy_df['budget'].max()/1_000_000, 100)\n",
    "plt.plot(x_line, p(x_line), \"r--\", alpha=0.8, label='Trend line')\n",
    "\n",
    "plt.xlabel('Production Budget ($ Millions)', fontsize=12)\n",
    "plt.ylabel('Box Office Revenue ($ Millions)', fontsize=12)\n",
    "plt.title('Comedy Films: Production Budget vs Box Office Revenue (2000-2016)', \n",
    "          fontsize=13, fontweight='bold')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('budget_vs_revenue.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Chart 2 saved!\")"
   ]
