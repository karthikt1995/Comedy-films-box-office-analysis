    "# CHART 6: Does Audience Rating Actually Drive Box Office Revenue?\n",
    "plt.figure(figsize=(10, 7))\n",
    "\n",
    "# Create scatter plot with color based on budget size\n",
    "scatter = plt.scatter(comedy_df['vote_average'], \n",
    "                      comedy_df['revenue']/1_000_000,\n",
    "                      c=comedy_df['budget']/1_000_000,\n",
    "                      cmap='YlOrRd',\n",
    "                      alpha=0.7,\n",
    "                      edgecolors='white',\n",
    "                      linewidth=0.5,\n",
    "                      s=60)\n",
    "\n",
    "# Add colorbar to show budget scale\n",
    "cbar = plt.colorbar(scatter)\n",
    "cbar.set_label('Production Budget ($ Millions)', fontsize=10)\n",
    "\n",
    "# Add trend line\n",
    "import numpy as np\n",
    "mask = comedy_df['vote_average'] > 0\n",
    "z = np.polyfit(comedy_df.loc[mask, 'vote_average'], \n",
    "               comedy_df.loc[mask, 'revenue']/1_000_000, 1)\n",
    "p = np.poly1d(z)\n",
    "x_line = np.linspace(comedy_df['vote_average'].min(), \n",
    "                     comedy_df['vote_average'].max(), 100)\n",
    "plt.plot(x_line, p(x_line), \"b--\", alpha=0.8, linewidth=2, label='Trend line')\n",
    "\n",
    "plt.xlabel('Audience Vote Average (out of 10)', fontsize=12)\n",
    "plt.ylabel('Box Office Revenue ($ Millions)', fontsize=12)\n",
    "plt.title('Comedy Films: Does Audience Rating Drive Box Office Revenue?\\n(2000-2016)', \n",
    "          fontsize=13, fontweight='bold')\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('rating_vs_revenue.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Chart 6 saved!\")"
   ]
